        <mxCell id="2" value="&lt;b&gt;引数の受け渡し方法（値渡し vs 参照渡し）&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="450" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="&lt;b&gt;値渡し（input/output）&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="280" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="&lt;b&gt;参照渡し（ref）&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="400" y="80" width="280" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="呼び出し時に&lt;br&gt;値をコピー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5d0;strokeColor=#82b366;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="100" y="120" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="関数内で&lt;br&gt;変更可能" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="220" y="120" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="呼び出し時に&lt;br&gt;アドレスを渡す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5d0;strokeColor=#82b366;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="420" y="120" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="8" value="関数内外で&lt;br&gt;同じ変数を参照" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="540" y="120" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="9" value="&lt;b&gt;特徴&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#f5f5f5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="190" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="10" value="• 呼び出し元に影響しない&lt;br&gt;• 変更が局所的&lt;br&gt;• コピーのオーバーヘッドあり" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="210" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;特徴&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#f5f5f5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="190" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="• 呼び出し元に影響する&lt;br&gt;• 変更が即座に反映&lt;br&gt;• コピーのオーバーヘッドなし" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="210" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="&lt;b&gt;コード例&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="80" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="// 値渡し（input/output）&lt;br&gt;task value_pass(input int a, output int b);&lt;br&gt;    a = a + 1;  // ローカルコピーを変更&lt;br&gt;    b = a * 2;  // 出力引数に代入&lt;br&gt;endtask&lt;br&gt;&lt;br&gt;int x = 10, y;&lt;br&gt;value_pass(x, y);&lt;br&gt;// x = 10 （変更されない）&lt;br&gt;// y = 22 （結果を受け取る）" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#6c8ebf;fillColor=#dae8fc;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="350" width="280" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="// 参照渡し（ref）&lt;br&gt;task ref_pass(ref int arr[$]);&lt;br&gt;    arr.push_back(5);  // 配列を直接操作&lt;br&gt;    arr[0] = 100;     // 変更が即座に反映&lt;br&gt;endtask&lt;br&gt;&lt;br&gt;int q[$] = {1, 2, 3};&lt;br&gt;ref_pass(q);&lt;br&gt;// q = {100, 2, 3, 5}&lt;br&gt;// 呼び出し元の配列が変更される" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#82b366;fillColor=#d5e8d4;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="400" y="350" width="280" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="&lt;b&gt;使用場面&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#fff2cc;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="80" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="17" value="&lt;b&gt;値渡し（input/output）&lt;/b&gt;: 単純な値の受け渡し、計算結果の返却&lt;br&gt;&lt;b&gt;参照渡し（ref）&lt;/b&gt;: 大きな配列/構造体の操作、複数の値を同時に変更" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=#d6b656;fillColor=#fff2cc;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="570" width="500" height="40" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
