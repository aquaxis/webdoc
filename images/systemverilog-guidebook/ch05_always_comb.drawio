          <mxGeometry x="100" y="240" width="200" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="always_comb は右辺の信号&#xa;(a, b) を自動的に感度リストに追加&#xa;&#xa;a または b が変化すると&#xa;自動的にブロックが再評価される" style="text;html=1;fontSize=12;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;arcSize=2;" vertex="1" parent="1">
          <mxGeometry x="70" y="275" width="360" height="100" as="geometry"/>
        </mxCell>
        <!-- Arrow from code to circuit -->
        <mxCell id="8" value="対応する回路" style="edgeStyle=orthogonalEdgeStyle;rounded=1;arcSize=2;strokeWidth=3;strokeColor=#2196F3;fontSize=13;fontStyle=1;" edge="1" parent="1">
