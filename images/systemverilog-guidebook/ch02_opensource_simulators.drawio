        <mxCell id="5" value="&lt;b&gt;特徴&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#f5f5f5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="120" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="• C++/SystemCベース高速シミュレータ&lt;br&gt;• 2値シミュレーション（0と1のみ）&lt;br&gt;• 合成可能RTLに特化&lt;br&gt;• Lint機能が優秀&lt;br&gt;• RISC-V等OSSで広く採用" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="140" y="145" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="&lt;b&gt;特徴&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#f5f5f5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="120" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="8" value="• 軽量でインストール容易&lt;br&gt;• 4値シミュレーション対応&lt;br&gt;• Verilog-2005サポート充実&lt;br&gt;• VPI対応（C連携可能）&lt;br&gt;• 学習用として歴史あり" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="145" width="240" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="9" value="&lt;b&gt;制限事項&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#ffdddd;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="240" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="10" value="✗ 4値論理（x, z）非対応&lt;br&gt;✗ fork-join等の並行制御が限定的&lt;br&gt;✗ タイミング制御が限定的&lt;br&gt;✗ UVMは部分的サポート" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="140" y="265" width="250" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;制限事項&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#ffdddd;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="240" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="✗ クラス・制約・アサーション非対応&lt;br&gt;✗ 大規模設計では低速&lt;br&gt;✗ UVM非サポート&lt;br&gt;✗ 新規格対応が遅い" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
