        </mxCell>
        <mxCell id="6" value="・C++ / SystemC ベース高速シミュレータ&lt;br&gt;・2 値シミュレーション（0 と 1 のみ）&lt;br&gt;・合成可能 RTL に特化&lt;br&gt;・Lint 機能が優秀&lt;br&gt;・RISC-V 等 OSS プロジェクトで広く採用" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="145" width="340" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="&lt;b&gt;特徴&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#f5f5f5;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="115" width="60" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="8" value="・軽量でインストール容易&lt;br&gt;・4 値シミュレーション対応&lt;br&gt;・Verilog-2005 サポート充実&lt;br&gt;・VPI 対応（C 連携可能）&lt;br&gt;・学習用として歴史あり" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="145" width="340" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="9" value="&lt;b&gt;制限事項&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#ffdddd;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="255" width="90" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="10" value="✗ 4 値論理（x, z）非対応&lt;br&gt;✗ fork-join 等の並行制御が限定的&lt;br&gt;✗ UVM は部分的サポート" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="285" width="300" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;制限事項&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#ffdddd;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="255" width="90" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="✗ クラス・制約・アサーション非対応&lt;br&gt;✗ 大規模設計では低速&lt;br&gt;✗ UVM 非サポート" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
