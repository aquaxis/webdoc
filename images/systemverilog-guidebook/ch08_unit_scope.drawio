        </mxCell>
        <mxCell id="14" value="• $unitで宣言した名前は&lt;br&gt;  全ファイルから参照可能&lt;br&gt;• パッケージ内の名前は&lt;br&gt;  importが必要&lt;br&gt;• モジュール内で宣言した&lt;br&gt;  名前はそのモジュール内&lt;br&gt;  でのみ有効" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#9673a6;fillColor=#e1d5e7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="150" width="150" height="110" as="geometry"/>
        </mxCell>
