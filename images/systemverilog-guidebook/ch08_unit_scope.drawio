        <mxCell id="12" value="// $unitの宣言参照&lt;br&gt;byte_t d1; // OK&lt;br&gt;// pkg内の宣言は&lt;br&gt;// importが必要&lt;br&gt;int32_t d2; // エラー!" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=none;fillColor=none;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
