          <mxGeometry x="100" y="380" width="60" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="• $unit変数の乱用は名前衝突の原因&lt;br&gt;• パッケージの使用を推奨&lt;br&gt;• できる限りスコープを限定する" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#b85450;fillColor=#f8cecc;fontSize=10;" vertex="1" parent="1">
