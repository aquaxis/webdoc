        </mxCell>
        <!-- union コード例 -->
        <mxCell id="30" value="&lt;font face=&quot;monospace&quot;&gt;typedef union packed {&lt;br&gt;  logic [7:0] byte_val;&lt;br&gt;  logic [3:0] nibble;&lt;br&gt;} my_union_t;&lt;/font&gt;" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
