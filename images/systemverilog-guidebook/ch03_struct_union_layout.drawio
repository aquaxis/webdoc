        </mxCell>
        <!-- union メモリレイアウト -->
        <mxCell id="8" value="&lt;b&gt;メモリレイアウト（8bit）&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];strokeColor=none;fillColor=none;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
