        <!-- struct コード例 -->
        <mxCell id="10" value="&lt;font face=&quot;monospace&quot;&gt;typedef struct packed {&lt;br&gt;  logic [7:0] a;  // 8bit&lt;br&gt;  logic [3:0] b;  // 4bit&lt;br&gt;  logic [3:0] c;  // 4bit&lt;br&gt;} my_struct_t;&lt;/font&gt;" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
