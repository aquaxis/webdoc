          <mxGeometry x="520" y="230" width="280" height="45" as="geometry"/>
        </mxCell>
        <!-- nibble [3:0] -->
        <mxCell id="32" value="&lt;b&gt;nibble [3:0]&lt;/b&gt;（4 bits）— 同じ領域を共有" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="520" y="280" width="280" height="45" as="geometry"/>
        </mxCell>
        <!-- union 合計 -->
        <mxCell id="33" value="合計: max(8, 4) = &lt;b&gt;8 bits&lt;/b&gt;（共有）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="520" y="335" width="280" height="30" as="geometry"/>
        </mxCell>
        <!-- === 主な違い === -->
        <mxCell id="50" value="&lt;b&gt;主な違い&lt;/b&gt;" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;fontColor=#ffffff;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="50" y="400" width="750" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="51" value="&lt;b&gt;構造体:&lt;/b&gt; 各メンバが独立した領域を持つ → サイズ = 全メンバの合計" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="430" width="750" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="52" value="&lt;b&gt;共用体:&lt;/b&gt; 全メンバが同じ領域を共有 → サイズ = 最大メンバのサイズ" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
