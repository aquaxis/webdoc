        <mxCell id="2" value="&lt;b&gt;条件付き制約（constraint ... if）&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="350" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="&lt;b&gt;基本構文&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="280" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="constraint name {&lt;br&gt;  if (condition) {&lt;br&gt;    // 条件がtrueの場合の制約&lt;br&gt;  } else {&lt;br&gt;    // 条件がfalseの場合の制約&lt;br&gt;  }&lt;br&gt;}" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=none;fillColor=none;fontSize=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="&lt;b&gt;実用例：モード依存の制約&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="400" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="class Packet;&lt;br&gt;  rand bit [1:0] mode;&lt;br&gt;  rand bit [31:0] addr;&lt;br&gt;&lt;br&gt;  constraint c_mode {&lt;br&gt;    if (mode == 2'b00) {         // READモード&lt;br&gt;      addr inside {[32'h0000_0000:32'h0000_FFFF]};&lt;br&gt;    } else if (mode == 2'b01) {   // WRITEモード&lt;br&gt;      addr inside {[32'h0001_0000:32'h0001_FFFF]};&lt;br&gt;    } else {                     // その他&lt;br&gt;      addr inside {[32'hFFFF_0000:32'hFFFF_FFFF]};&lt;br&gt;    }&lt;br&gt;  }&lt;br&gt;endclass" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=none;fillColor=none;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="100" y="240" width="380" height="160" as="geometry"/>
        </mxCell>
