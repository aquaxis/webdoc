        <mxCell id="33" value="&lt;b&gt;アサーションコード例&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#e1d5e7;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="310" width="140" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="34" value="// VALIDはREADYまで保持&lt;br&gt;property axi_valid_stable;&lt;br&gt;  @(posedge aclk) disable iff (!aresetn)&lt;br&gt;    (awvalid &amp;&amp; !awready) |-&gt;&lt;br&gt;      next(awvalid);&lt;br&gt;endproperty&lt;br&gt;&lt;br&gt;// DATAはVALID中に安定&lt;br&gt;property axi_data_stable;&lt;br&gt;  @(posedge aclk) disable iff (!aresetn)&lt;br&gt;    (awvalid &amp;&amp; !awready) |-&gt;&lt;br&gt;      $stable(awaddr);&lt;br&gt;endproperty&lt;br&gt;&lt;br&gt;// アサーションの適用&lt;br&gt;assert property (axi_valid_stable)&lt;br&gt;  else $error(&quot;VALID dropped&quot;);&lt;br&gt;assert property (axi_data_stable)&lt;br&gt;  else $error(&quot;DATA changed&quot;);" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#9673a6;fillColor=#e1d5e7;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="80" y="350" width="280" height="240" as="geometry"/>
        </mxCell>
