        <mxCell id="15" value="&lt;font face=&quot;monospace&quot;&gt;typedef enum logic [2:0] {&lt;br&gt;    IDLE   = 3'b000,&lt;br&gt;    FETCH  = 3'b001,&lt;br&gt;    DECODE = 3'b010,&lt;br&gt;    EXEC   = 3'b011,&lt;br&gt;    WRITE  = 3'b100&lt;br&gt;} cpu_state_t;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#6c8ebf;fillColor=#dae8fc;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
