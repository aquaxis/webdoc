<mxfile host="app.diagrams.net" modified="2026-04-08T00:00:00.000Z" agent="Mozilla/5.0" version="22.1.0">
  <diagram id="ch04_packed_vs_unpacked" name="パック配列とアンパック配列のメモリ配置">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- タイトル -->
        <mxCell id="2" value="&lt;b&gt;パック配列 vs アンパック配列 — メモリレイアウト比較&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="15" width="560" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== パック配列セクション ===== -->
        <mxCell id="3" value="&lt;b&gt;パック配列（Packed Array）&lt;/b&gt;" style="text;html=1;fontSize=16;fontStyle=1;align=center;fontColor=#1a5276;" vertex="1" parent="1">
          <mxGeometry x="100" y="70" width="380" height="30" as="geometry"/>
        </mxCell>
        <!-- 宣言コード -->
        <mxCell id="4" value="&lt;font face=&quot;monospace&quot;&gt;logic [3:0][7:0] packed_data;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;rounded=1;arcSize=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="100" y="105" width="350" height="30" as="geometry"/>
        </mxCell>
        <!-- 背景枠 -->
        <mxCell id="5" value="" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="60" y="145" width="440" height="340" as="geometry"/>
        </mxCell>
        <!-- メモリ説明 -->
        <mxCell id="6" value="&lt;b&gt;連続したビットベクタ（32 ビット）&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontColor=#1a5276;" vertex="1" parent="1">
          <mxGeometry x="120" y="155" width="300" height="25" as="geometry"/>
        </mxCell>
        <!-- ビットブロック全体 -->
        <mxCell id="7" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="190" width="380" height="60" as="geometry"/>
        </mxCell>
        <!-- [3] -->
        <mxCell id="8" value="[3]&lt;br&gt;ビット 31:24" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="190" width="95" height="60" as="geometry"/>
        </mxCell>
        <!-- [2] -->
        <mxCell id="9" value="[2]&lt;br&gt;ビット 23:16" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b6d7f2;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="195" y="190" width="95" height="60" as="geometry"/>
        </mxCell>
        <!-- [1] -->
        <mxCell id="10" value="[1]&lt;br&gt;ビット 15:8" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="290" y="190" width="95" height="60" as="geometry"/>
        </mxCell>
        <!-- [0] -->
        <mxCell id="11" value="[0]&lt;br&gt;ビット 7:0" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b6d7f2;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="385" y="190" width="95" height="60" as="geometry"/>
        </mxCell>
        <!-- MSB/LSBラベル -->
        <mxCell id="12" value="MSB" style="text;html=1;align=center;fontSize=12;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="100" y="255" width="45" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="LSB" style="text;html=1;align=center;fontSize=12;fontColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="435" y="255" width="45" height="20" as="geometry"/>
        </mxCell>
        <!-- 特徴ボックス -->
        <mxCell id="14" value="・全ビットが連続メモリに配置&lt;br&gt;・ビット演算・スライスが可能&lt;br&gt;・ポート接続にそのまま使用可能&lt;br&gt;・合成可能（ハードウェアに直接対応）" style="text;html=1;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;rounded=1;arcSize=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="290" width="340" height="80" as="geometry"/>
        </mxCell>
        <!-- ビットスライスの例 -->
        <mxCell id="15" value="&lt;font face=&quot;monospace&quot;&gt;packed_data[1] = 8'hFF;&lt;br&gt;packed_data[2][3:0] = 4'b1010;&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=1;arcSize=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="385" width="310" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="ビット単位でアクセス可能" style="text;html=1;align=center;fontSize=12;fontColor=#d79b00;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="430" width="200" height="25" as="geometry"/>
        </mxCell>

        <!-- ===== アンパック配列セクション ===== -->
        <mxCell id="20" value="&lt;b&gt;アンパック配列（Unpacked Array）&lt;/b&gt;" style="text;html=1;fontSize=16;fontStyle=1;align=center;fontColor=#1a5276;" vertex="1" parent="1">
          <mxGeometry x="700" y="70" width="400" height="30" as="geometry"/>
        </mxCell>
        <!-- 宣言コード -->
        <mxCell id="21" value="&lt;font face=&quot;monospace&quot;&gt;logic [7:0] unpacked_data [4];&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;fillColor=#f5f5f5;strokeColor=#cccccc;rounded=1;arcSize=2;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="720" y="105" width="350" height="30" as="geometry"/>
        </mxCell>
        <!-- 背景枠 -->
        <mxCell id="22" value="" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="660" y="145" width="440" height="340" as="geometry"/>
        </mxCell>
        <!-- メモリ説明 -->
        <mxCell id="23" value="&lt;b&gt;個別のメモリ領域（各 8 ビット + パディング）&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontSize=13;fontColor=#1a5276;" vertex="1" parent="1">
          <mxGeometry x="720" y="155" width="350" height="25" as="geometry"/>
        </mxCell>
        <!-- 各要素 -->
        <mxCell id="24" value="[0] : 8 ビット" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="740" y="190" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="25" value="padding" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=12;fontColor=#999999;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="190" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="26" value="[1] : 8 ビット" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="740" y="240" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="27" value="padding" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=12;fontColor=#999999;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="240" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="28" value="[2] : 8 ビット" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="740" y="290" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="29" value="padding" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=12;fontColor=#999999;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="290" width="80" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="30" value="[3] : 8 ビット" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="740" y="340" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="padding" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;fontSize=12;fontColor=#999999;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="340" width="80" height="40" as="geometry"/>
        </mxCell>
        <!-- 特徴ボックス -->
        <mxCell id="32" value="・各要素が独立したメモリ領域&lt;br&gt;・要素単位のアクセス&lt;br&gt;・ビットスライス不可&lt;br&gt;・要素間にパディングの可能性" style="text;html=1;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;rounded=1;arcSize=2;" vertex="1" parent="1">
          <mxGeometry x="720" y="395" width="330" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== 中央の比較 ===== -->
        <mxCell id="40" value="&lt;b&gt;vs&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontColor=#FF6600;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="210" width="60" height="40" as="geometry"/>
        </mxCell>
        <!-- 下部サマリ -->
        <mxCell id="41" value="&lt;b&gt;使い分けの指針&lt;/b&gt;：パック → ビット操作・ポート接続　|　アンパック → メモリ配列・テストベンチ" style="text;html=1;align=center;verticalAlign=middle;fillColor=#E8EAF6;strokeColor=#7986CB;rounded=1;arcSize=2;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="220" y="500" width="700" height="35" as="geometry"/>
        </mxCell>
      </root>
