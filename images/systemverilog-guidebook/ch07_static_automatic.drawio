        <mxCell id="7" value="&lt;b&gt;用途例&lt;/b&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#f5f5f5;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="190" width="60" height="20" as="geometry"/>
