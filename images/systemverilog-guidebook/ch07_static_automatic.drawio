        <mxCell id="8" value="• 呼び出し回数カウンタ&lt;br&gt;• 共有ステート管理&lt;br&gt;• シングルトンパターン" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=10;" vertex="1" parent="1">
