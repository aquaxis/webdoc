        </mxCell>
        <mxCell id="33" value="• covergroup: カバレッジモデルのコンテナ&lt;br&gt;• coverpoint: 変数のカバレッジ定義&lt;br&gt;• bins: 値の分類（ビン）&lt;br&gt;• cross: coverpoint間の組み合わせ" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#b85450;fillColor=#f8cecc;fontSize=10;" vertex="1" parent="1">
