        <mxCell id="31" value="covergroup bus_cov @(posedge clk);&lt;br&gt;  addr_cp: coverpoint addr {&lt;br&gt;    bins low_addr   = {...};&lt;br&gt;    bins mid_addr   = {...};&lt;br&gt;  }&lt;br&gt;&lt;br&gt;  rw_cp: coverpoint write {&lt;br&gt;    bins read  = {0};&lt;br&gt;    bins write = {1};&lt;br&gt;  }&lt;br&gt;&lt;br&gt;  // クロスカバレッジ&lt;br&gt;  addr_rw: cross addr_cp, rw_cp;&lt;br&gt;endgroup" style="text;html=1;align=left;verticalAlign=top;resizable=0;points=[];strokeColor=#9673a6;fillColor=#e1d5e7;fontSize=9;fontFamily=Courier New;" vertex="1" parent="1">
