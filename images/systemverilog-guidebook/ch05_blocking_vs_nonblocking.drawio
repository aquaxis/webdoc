<mxfile host="app.diagrams.net" modified="2026-04-08T00:00:00.000Z" agent="draw.io" version="22.0.0">
  <diagram name="ブロッキング代入とノンブロッキング代入の違い" id="ch05_blocking_vs_nonblocking">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="2" value="ブロッキング代入とノンブロッキング代入の違い" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="40" as="geometry"/>
        </mxCell>
        <!-- Blocking Section -->
        <mxCell id="3" value="" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="700" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="ブロッキング代入 ( = )  ─ 逐次実行" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="50" y="90" width="400" height="30" as="geometry"/>
        </mxCell>
        <!-- Blocking Code -->
        <mxCell id="5" value="&lt;font face=&quot;Courier New&quot;&gt;always_ff @(posedge clk) begin&lt;br&gt;  b = a;   // (1) 先に実行&lt;br&gt;  c = b;   // (2) bは既にaの値&lt;br&gt;end&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#E65100;fontSize=13;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="50" y="130" width="330" height="100" as="geometry"/>
        </mxCell>
        <!-- Blocking Timing -->
        <mxCell id="6" value="実行タイミング" style="text;html=1;fontSize=13;fontStyle=1;align=center;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="440" y="130" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="posedge clk" style="text;html=1;fontSize=12;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="445" y="155" width="120" height="20" as="geometry"/>
        </mxCell>
        <!-- Step 1 -->
        <mxCell id="8" value="(1) b = a" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="185" width="150" height="40" as="geometry"/>
        </mxCell>
        <!-- Arrow down -->
        <mxCell id="9" value="完了後" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;strokeColor=#E65100;fontSize=12;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="515" y="225" as="sourcePoint"/>
            <mxPoint x="515" y="245" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Step 2 -->
        <mxCell id="10" value="(2) c = b (= a)" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFCC80;strokeColor=#E65100;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="250" width="150" height="40" as="geometry"/>
        </mxCell>
        <!-- Result -->
        <mxCell id="11" value="結果: b = a, c = a（同じ値！）" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#FFECB3;strokeColor=#E65100;fontSize=13;fontStyle=1;fontColor=#BF360C;" vertex="1" parent="1">
          <mxGeometry x="50" y="250" width="330" height="40" as="geometry"/>
        </mxCell>
        <!-- Blocking circuit diagram -->
        <mxCell id="12" value="生成される回路" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="150" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="a" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="345" width="70" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="FF" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="342" width="70" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="b = c" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="330" y="345" width="70" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="16" style="strokeWidth=2;strokeColor=#333;" edge="1" source="13" target="14" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="17" style="strokeWidth=2;strokeColor=#333;" edge="1" source="14" target="15" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="18" value="FF 1段のみ（シフトしない）" style="text;html=1;fontSize=12;align=center;fontColor=#BF360C;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="150" y="392" width="200" height="20" as="geometry"/>
        </mxCell>
        <!-- Non-blocking Section -->
        <mxCell id="19" value="" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="450" width="700" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="20" value="ノンブロッキング代入 ( &lt;= )  ─ 同時更新" style="text;html=1;fontSize=16;fontStyle=1;align=left;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="50" y="460" width="420" height="30" as="geometry"/>
        </mxCell>
        <!-- Non-blocking Code -->
        <mxCell id="21" value="&lt;font face=&quot;Courier New&quot;&gt;always_ff @(posedge clk) begin&lt;br&gt;  b &amp;lt;= a;  // (1) 同時にスケジュール&lt;br&gt;  c &amp;lt;= b;  // (2) bは旧値を使用&lt;br&gt;end&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2E7D32;fontSize=13;align=left;spacingLeft=15;" vertex="1" parent="1">
          <mxGeometry x="50" y="500" width="330" height="100" as="geometry"/>
        </mxCell>
        <!-- Non-blocking Timing -->
        <mxCell id="22" value="実行タイミング" style="text;html=1;fontSize=13;fontStyle=1;align=center;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="440" y="500" width="140" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="posedge clk" style="text;html=1;fontSize=12;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="445" y="525" width="120" height="20" as="geometry"/>
        </mxCell>
        <!-- Parallel Steps -->
        <mxCell id="24" value="(1) b &lt;= a" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="555" width="130" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="25" value="(2) c &lt;= b" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="580" y="555" width="130" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="26" value="同時実行" style="text;html=1;fontSize=12;fontStyle=1;fontColor=#2E7D32;align=center;" vertex="1" parent="1">
          <mxGeometry x="490" y="600" width="100" height="20" as="geometry"/>
        </mxCell>
        <!-- Result -->
        <mxCell id="27" value="結果: b = a(旧), c = b(旧)（異なる値）" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=13;fontStyle=1;fontColor=#1B5E20;" vertex="1" parent="1">
          <mxGeometry x="50" y="625" width="330" height="40" as="geometry"/>
        </mxCell>
        <!-- Non-blocking circuit diagram -->
        <mxCell id="28" value="生成される回路" style="text;html=1;fontSize=12;fontStyle=1;align=center;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="100" y="680" width="150" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="29" value="a" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="50" y="715" width="60" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="30" value="FF" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="712" width="70" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="b" style="text;html=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="718" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="FF" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="712" width="70" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="33" value="c" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="420" y="715" width="60" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="34" style="strokeWidth=2;strokeColor=#333;" edge="1" source="29" target="30" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="35" style="strokeWidth=2;strokeColor=#333;" edge="1" source="30" target="32" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="36" style="strokeWidth=2;strokeColor=#333;" edge="1" source="32" target="33" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="37" value="FF 2段（正しいシフトレジスタ）" style="text;html=1;fontSize=12;align=center;fontColor=#1B5E20;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="180" y="760" width="230" height="20" as="geometry"/>
        </mxCell>
        <!-- Summary Box -->
        <mxCell id="38" value="まとめ: always_ff 内ではノンブロッキング代入(&lt;=)を使用すること！" style="rounded=1;arcSize=2;whiteSpace=wrap;html=1;fillColor=#F44336;strokeColor=#B71C1C;fontSize=14;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="150" y="810" width="500" height="40" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
